{
  "name": "dashrunner-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "DashRunner API — Fastify, TypeScript, Knex (SQLite dev / MySQL prod)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "knex": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:rollback": "npm run knex -- migrate:rollback",
    "migrate:make": "npm run knex -- migrate:make",
    "seed": "npm run knex -- seed:run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "knex": "^3.2.9",
    "mysql2": "^3.22.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

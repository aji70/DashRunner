# Copy to `.env` and adjust. Loaded automatically via dotenv.

NODE_ENV=development

HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# --- SQLite (development / test; default file below) ---
SQLITE_PATH=./data/dev.sqlite3

# Knex CLI uses NODE_ENV to choose SQLite (development) vs MySQL (production).
# Roll back against SQLite locally: npm run migrate:rollback:sqlite
# (Do not rely on NODE_ENV=production in the shell unless DB_* points at a reachable MySQL.)

# --- MySQL (production / NODE_ENV=production for Knex; required DB_* below) ---
# Prefer 127.0.0.1 over localhost (avoids IPv6 ::1 vs mysqld on IPv4-only).
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=dashrunner
# DB_PASSWORD=secret
# DB_NAME=dashrunner
# DB_SSL=false

# CORS: omit in dev → reflects Origin. In prod omit → no CORS until you set explicitly.
# CORS_ORIGIN=true
# CORS_ORIGIN=false
# CORS_ORIGIN=https://your-frontend.example.com
# CORS_ORIGIN=https://a.example.com,https://b.example.com

# Copy to `.env` and adjust. Loaded automatically via dotenv.

NODE_ENV=development

HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# --- SQLite (development / test; default file below) ---
SQLITE_PATH=./data/dev.sqlite3

# Knex migrations (npm run migrate:*): scripts/knex-env.mjs picks the profile:
#   • MySQL when DB_HOST is set (Knex env production)
#   • SQLite when DB_HOST is unset (Knex env development), even if NODE_ENV=production
# Override: KNEX_ENV=development | KNEX_ENV=production
# Force SQLite while DB_* is present: npm run migrate:rollback:sqlite

# --- MySQL (Knex production profile when DB_HOST is set; fill DB_* below) ---
# Prefer 127.0.0.1 over localhost (avoids IPv6 ::1 vs mysqld on IPv4-only).
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=dashrunner
# DB_PASSWORD=secret
# DB_NAME=dashrunner
# DB_SSL=false

# CORS: omit in dev → reflects Origin. In prod omit → no CORS until you set explicitly.
# CORS_ORIGIN=true
# CORS_ORIGIN=false
# CORS_ORIGIN=https://your-frontend.example.com
# CORS_ORIGIN=https://a.example.com,https://b.example.com

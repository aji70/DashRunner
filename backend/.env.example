PORT=4100
NODE_ENV=development
DASHRUNNER_CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Optional: read-only chain snapshot for GET /api/player/:wallet
DASHRUNNER_RPC_URL=
